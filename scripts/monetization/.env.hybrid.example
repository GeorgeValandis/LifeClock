# ---------- Shared app identifiers ----------
RC_BUNDLE_ID=com.GA.LifeClock
RC_STORE_PRODUCT_ID=com.GA.LifeClock.lifetime
RC_LIFETIME_PRODUCT_ID=com.GA.LifeClock.lifetime

# ---------- App Store Connect API (Apple) ----------
# Issuer ID and Key ID from App Store Connect > Users and Access > Integrations > App Store Connect API
APPLE_ISSUER_ID=
APPLE_KEY_ID=

# Absolute path to your downloaded App Store Connect API private key (.p8)
APPLE_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXX.p8

# Numeric ASC app ID (not bundle id)
APPLE_APP_ID=

# IAP to ensure
ASC_PRODUCT_ID=com.GA.LifeClock.lifetime
ASC_IAP_NAME="LifeClock Lifetime"
ASC_IAP_TYPE=NON_CONSUMABLE
ASC_FAMILY_SHARABLE=false
ASC_REVIEW_NOTE=
ASC_LOCALE=de-DE
ASC_LOCALIZED_NAME="LifeClock Lifetime"
ASC_LOCALIZED_DESCRIPTION="Einmaliger Kauf für Premium-Funktionen."
ASC_ENABLE_ALL_TERRITORIES=false
ASC_AVAILABLE_IN_NEW_TERRITORIES=true
ASC_PRICE_BASE_TERRITORY=DEU
ASC_PRICE_CUSTOMER=
ASC_PRICE_START_DATE=

# ---------- RevenueCat API v2 ----------
# Secret API key (v2) with project_configuration read/write scopes
RC_API_KEY=

# Use one of these:
RC_PROJECT_ID=
RC_PROJECT_NAME=LifeClock

# Optional: force specific app if it already exists
RC_APP_ID=
RC_APP_NAME="LifeClock iOS"
RC_APP_TYPE=app_store

# Product/entitlement/offering/package setup
RC_PRODUCT_TYPE=non_consumable
RC_PRODUCT_DISPLAY_NAME="LifeClock Lifetime"
RC_ENTITLEMENT_LOOKUP_KEY=premium
RC_ENTITLEMENT_DISPLAY_NAME=Premium
RC_OFFERING_LOOKUP_KEY=default
RC_OFFERING_DISPLAY_NAME="Default Offering"
RC_PACKAGE_LOOKUP_KEY=lifetime
RC_PACKAGE_DISPLAY_NAME=Lifetime
RC_PACKAGE_POSITION=1
RC_PACKAGE_ELIGIBILITY=all
RC_SET_CURRENT_OFFERING=true

# Optional: also update ASC credentials inside RevenueCat app settings
RC_APPSTORE_CONNECT_API_KEY_PATH=
RC_APPSTORE_CONNECT_API_KEY_ID=
RC_APPSTORE_CONNECT_API_KEY_ISSUER=
RC_APPSTORE_CONNECT_VENDOR_NUMBER=
RC_APPSTORE_SHARED_SECRET=

# ---------- Xcode patch fallback ----------
# Usually fetched automatically from RevenueCat app public API keys.
# Only needed if auto-fetch is not available.
RC_PUBLIC_SDK_KEY=
REVENUECAT_PUBLIC_SDK_KEY=
